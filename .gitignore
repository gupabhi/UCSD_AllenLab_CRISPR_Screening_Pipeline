# =============================================================================
# Large sequencing data — never commit these
# =============================================================================

# Raw sequencing reads
*.fastq
*.fastq.gz
*.fq.gz
*.bam
*.sam
*.fasta
*.fna
*.tar.gz

# =============================================================================
# Pipeline input data (large annotation/library files)
# Exception: small config CSVs like metadata and mle_comparison_pairs ARE tracked
# =============================================================================

# Sequencing subfolders
input/*/2_sequencing/

# Large annotation source files
input/*/3_annotation/*.annotations
input/*/3_annotation/*.emapper.*
input/*/3_annotation/*.txt
input/*/3_annotation/*.tsv

# Processed/derived annotation databases (regenerated by Step 11)
input/*/3_annotation/processed/

# sgRNA library files (large, should be stored separately or on TSCC)
input/*/1_sgRNAs/*.csv
input/*/1_sgRNAs/*.txt

# =============================================================================
# Pipeline output data (large, regenerated by running the pipeline)
# =============================================================================

# Preprocessed reads (can be 10s of GB)
output/*/1_preprocess_reads/*.fastq.gz

# MAGeCK count outputs (large count tables)
output/*/2_mageck_count/*.count.txt
output/*/2_mageck_count/*.count_normalized.txt
output/*/2_mageck_count/*.countsummary.txt

# MAGeCK MLE outputs
output/*/4_mageck_mle/**/*.sgrna_summary.txt
output/*/4_mageck_mle/**/*.gene_summary.txt

# Plots (large PNGs — download from TSCC directly)
output/**/*.png

# =============================================================================
# What IS tracked (small, important config/result files)
# =============================================================================
# These are intentionally NOT ignored:
#   metadata_*.csv              — sample metadata
#   mle_comparison_pairs.csv    — comparison selector
#   design_matrix_*.txt         — filled design matrices
#   *_normalized_hits.csv       — final hit tables (small)
#   *_ANNOTATED.csv             — annotated hit tables (small)
#   Master_Hits_*_Summary.csv   — master hit summaries

# =============================================================================
# Logs (regenerated each run)
# =============================================================================
logs/

# =============================================================================
# Python cache
# =============================================================================
__pycache__/
*.pyc
*.pyo

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
